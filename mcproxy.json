{
  "servers": [
    {
      "name": "fear_greed_index",
      "command": "/usr/bin/npx",
      "args": [
        "-y",
        "mcp-server-fear-greed"
      ],
      "env": {
        "PATH": "/usr/bin:/usr/local/bin:/bin"
      },
      "timeout": 60,
      "enabled": true
    },
    {
      "name": "sequential_thinking",
      "command": "/usr/bin/npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "env": {
        "PATH": "/usr/bin:/usr/local/bin:/bin"
      },
      "timeout": 60,
      "enabled": true
    },
    {
      "name": "atom_of_thoughts",
      "command": "/usr/bin/node",
      "args": [
        "/tmp/MCP_Atom_of_Thoughts/build/index.js"
      ],
      "env": {
        "PATH": "/usr/bin:/usr/local/bin:/bin"
      },
      "timeout": 60,
      "enabled": true
    },
    {
      "name": "think_tool",
      "command": "/usr/bin/npx",
      "args": [
        "-y",
        "think-tool-mcp"
      ],
      "env": {
        "PATH": "/usr/bin:/usr/local/bin:/bin"
      },
      "timeout": 60,
      "enabled": true
    },
    {
      "name": "coinstats",
      "command": "/usr/bin/npx",
      "args": [
        "-y",
        "@coinstats/coinstats-mcp"
      ],
      "env": {
        "PATH": "/usr/bin:/usr/local/bin:/bin",
        "COINSTATS_API_KEY": "${COINSTATS_API_KEY}"
      },
      "timeout": 60,
      "enabled": true
    },
    {
      "name": "llms_txt",
      "command": "/usr/bin/uvx",
      "args": [
        "mcpdoc",
        "--urls",
        "LangGraph:https://langchain-ai.github.io/langgraph/llms.txt",
        "--transport",
        "stdio"
      ],
      "env": {
        "PATH": "/usr/bin:/usr/local/bin:/bin"
      },
      "timeout": 60,
      "enabled": true
    },
    {
      "name": "youtube",
      "command": "/usr/bin/npx",
      "args": [
        "-y",
        "@anaisbetts/mcp-youtube"
      ],
      "env": {
        "PATH": "/usr/bin:/usr/local/bin:/bin"
      },
      "timeout": 60,
      "enabled": true
    },
    {
      "name": "wikipedia",
      "command": "/usr/bin/npx",
      "args": [
        "-y",
        "wikipedia-mcp"
      ],
      "env": {
        "PATH": "/usr/bin:/usr/local/bin:/bin"
      },
      "timeout": 60,
      "enabled": true
    },
    {
      "name": "tmux",
      "command": "/usr/bin/npx",
      "args": [
        "-y",
        "@executeautomation/tmux-mcp-server"
      ],
      "env": {
        "PATH": "/usr/bin:/usr/local/bin:/bin"
      },
      "timeout": 60,
      "enabled": true
    },
    {
      "name": "asset_price",
      "command": "/usr/bin/npx",
      "args": [
        "-y",
        "asset-price-mcp"
      ],
      "env": {
        "PATH": "/usr/bin:/usr/local/bin:/bin"
      },
      "timeout": 60,
      "enabled": true
    },
    {
      "name": "pure_md",
      "command": "/usr/bin/npx",
      "args": [
        "-y",
        "puremd-mcp"
      ],
      "env": {
        "PATH": "/usr/bin:/usr/local/bin:/bin",
        "PUREMD_API_KEY": "${PUREMD_API_KEY}"
      },
      "timeout": 60,
      "enabled": true
    },
    {
      "name": "playwright",
      "command": "/usr/bin/npx",
      "args": [
        "-y",
        "@executeautomation/playwright-mcp-server"
      ],
      "env": {
        "PATH": "/usr/bin:/usr/local/bin:/bin"
      },
      "timeout": 60,
      "enabled": true
    },
    {
      "name": "perplexity_sonar",
      "command": "/usr/bin/uvx",
      "args": [
        "perplexity-mcp"
      ],
      "env": {
        "PATH": "/usr/bin:/usr/local/bin:/bin",
        "PERPLEXITY_MODEL": "sonar",
        "PERPLEXITY_API_KEY": "${PERPLEXITY_API_KEY}"
      },
      "timeout": 60,
      "enabled": true
    },
    {
      "name": "jesse",
      "type": "http",
      "url": "http://localhost:12011/mcp",
      "env": {
        "PATH": "/usr/bin:/usr/local/bin:/bin",
        "JESSE_URL": "http://localhost:9100",
        "JESSE_PASSWORD": "jessesecurepassword2025",
        "PYTHONPATH": "/srv/containers/jesse:/srv/containers/jesse-baremetal/venv/lib/python3.11/site-packages",
        "LLM_ENDPOINT": "https://api.perplexity.ai",
        "LLM_API_KEY": "${PERPLEXITY_API_KEY}"
      },
      "timeout": 350,
      "tool_timeout": 600,
      "tool_timeouts": {
        "backtest": 900,
        "optimize": 1200,
        "walk_forward": 1800
      },
      "enabled": true
    },
    {
      "name": "coinmarketcap",
      "command": "/srv/containers/mcproxy/venv/bin/python",
      "args": [
        "-m",
        "coin_api_mcp"
      ],
      "env": {
        "PATH": "/usr/bin:/usr/local/bin:/bin",
        "COINMARKETCAP_API_KEY": "${CMC_API_KEY}"
      },
      "timeout": 60,
      "enabled": true
    },
    {
      "name": "home_assistant",
      "command": "/usr/bin/npx",
      "args": [
        "-y",
        "@coolver/home-assistant-mcp@latest"
      ],
      "env": {
        "PATH": "/usr/bin:/usr/local/bin:/bin",
        "HA_AGENT_URL": "http://192.168.50.99:8099",
        "HA_AGENT_KEY": "ZUAUTBnvtXROPLmCVU0WZPKGN50oBA6AXbneKUfyZvo"
      },
      "timeout": 60,
      "enabled": true
    }
  ],
  "namespaces": {
    "thinking": {
      "servers": [
        "sequential_thinking",
        "atom_of_thoughts",
        "think_tool"
      ],
      "isolated": false,
      "extends": []
    },
    "financial": {
      "servers": [
        "fear_greed_index",
        "coinstats",
        "asset_price",
        "coinmarketcap"
      ],
      "isolated": false
    },
    "docs": {
      "servers": [
        "llms_txt",
        "wikipedia"
      ],
      "isolated": false
    },
    "web": {
      "servers": [
        "pure_md",
        "perplexity_sonar",
        "youtube"
      ],
      "isolated": false
    },
    "automation": {
      "servers": [
        "tmux",
        "playwright"
      ],
      "isolated": false
    },
    "trading": {
      "servers": [
        "jesse"
      ],
      "isolated": true
    },
    "home": {
      "servers": [
        "home_assistant"
      ],
      "isolated": false,
      "extends": []
    }
  },
  "groups": {
    "dev": {
      "namespaces": [
        "thinking",
        "docs"
      ]
    },
    "dev_full": {
      "namespaces": [
        "thinking",
        "docs",
        "web"
      ]
    },
    "research": {
      "namespaces": [
        "thinking",
        "docs",
        "web",
        "financial"
      ]
    },
    "automation_full": {
      "namespaces": [
        "automation",
        "web"
      ]
    },
    "everything": {
      "namespaces": [
        "thinking",
        "financial",
        "docs",
        "web",
        "automation",
        "!trading"
      ]
    },
    "maxitrader": {
      "namespaces": [
        "thinking",
        "financial",
        "docs",
        "web",
        "!trading"
      ]
    },
    "normal": {
      "namespaces": [
        "automation",
        "docs",
        "home",
        "thinking",
        "web"
      ]
    }
  },
  "_hot_reload_test": "test_1772485402.0523033",
  "search": {
    "min_words": 2,
    "max_tools": 5
  },
  "sandbox": {
    "timeout_secs": 900,
    "pool": {
      "size": 3,
      "max_size": 10,
      "idle_timeout_secs": 300
    }
  }
}
